{
  "name": "escher-droste-renderer",
  "version": "1.0.0",
  "description": "Droste conformal renderer based on de Smit & Lenstra (2003) — Escher Print Gallery mathematics",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build-win": "electron-builder --win",
    "build-mac": "electron-builder --mac",
    "build-linux": "electron-builder --linux"
  },
  "keywords": ["escher", "droste", "conformal-map", "elliptic-curve", "complex-analysis"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.escher.droste",
    "productName": "Escher Droste Renderer",
    "directories": { "output": "dist" },
    "files": ["index.html", "main.js"],
    "win": { "target": "nsis" },
    "mac": { "target": "dmg" },
    "linux": { "target": "AppImage" }
  }
}
